# =============================================================================
# ProcureIntel Hybrid RAG Environment Variables Configuration Template
# =============================================================================

# 1. Google Gemini API Configuration (Mandatory)
# Get a key from: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_gemini_api_key_here

# LLM Model choices: "gemini-2.0-flash" (default), "gemini-2.5-flash", etc.
GEMINI_MODEL=gemini-2.0-flash

# 2. Live Supplier Discovery & Web Search Configuration
# DuckDuckGo is used by default (completely free, zero keys required).
# You can optionally provide a Tavily Search key to act as a fallback:

# Fallback: Tavily Search API Key
# Get a key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# 3. Application Network Configuration (Optional)
# Port and address for the backend FastAPI service
BACKEND_URL=http://127.0.0.1:8000

# 4. Groq API Configuration (Mandatory for Groq LLM / Llama 3.2 synthesis)
# Get a key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
